<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Daiv3.App.Maui.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Daiv3.App.Maui"
    xmlns:pages="clr-namespace:Daiv3.App.Maui.Pages"
    Title="DAIv3">

    <TabBar>
        <ShellContent
            Title="Dashboard"
            Icon="home.png"
            ContentTemplate="{DataTemplate pages:DashboardPage}"
            Route="DashboardPage" />

        <ShellContent
            Title="Chat"
            Icon="chat.png"
            ContentTemplate="{DataTemplate pages:ChatPage}"
            Route="ChatPage" />

        <ShellContent
            Title="Projects"
            Icon="folder.png"
            ContentTemplate="{DataTemplate pages:ProjectsPage}"
            Route="ProjectsPage" />

        <ShellContent
            Title="Settings"
            Icon="settings.png"
            ContentTemplate="{DataTemplate pages:SettingsPage}"
            Route="SettingsPage" />
    </TabBar>

</Shell>
