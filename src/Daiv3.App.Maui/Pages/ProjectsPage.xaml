<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Daiv3.App.Maui.ViewModels"
             x:Class="Daiv3.App.Maui.Pages.ProjectsPage"
             x:DataType="vm:ProjectsViewModel"
             Title="{Binding Title}">

    <Grid RowDefinitions="Auto,*">
        
        <!-- Toolbar -->
        <HorizontalStackLayout Grid.Row="0"
                              Padding="15"
                              Spacing="10"
                              BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1A212B}">
            <Button Text="New Project"
                    Command="{Binding CreateProjectCommand}" />
        </HorizontalStackLayout>

        <!-- Projects List -->
        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding Projects}"
                        SelectionMode="Single"
                        SelectedItem="{Binding SelectedProject}"
                        Margin="10">
            <CollectionView.EmptyView>
                <VerticalStackLayout VerticalOptions="Center"
                                    HorizontalOptions="Center"
                                    Spacing="10">
                    <Label Text="No projects yet"
                           FontSize="18"
                           TextColor="{AppThemeBinding Light=#334155, Dark=#CBD5E1}"
                           HorizontalOptions="Center" />
                    <Label Text="Click 'New Project' to create one"
                           FontSize="14"
                           TextColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="vm:ProjectItem">
                        <Border Padding="15"
                            Margin="5"
                            BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1A212B}"
                            StrokeShape="RoundRectangle 8"
                            StrokeThickness="0">
                        <Grid ColumnDefinitions="*,Auto"
                              RowDefinitions="Auto,Auto,Auto">
                            
                            <!-- Project Name -->
                            <Label Grid.Row="0" Grid.Column="0"
                                   Text="{Binding Name}"
                                   FontSize="18"
                                   FontAttributes="Bold" />

                            <!-- Delete Button -->
                            <Button Grid.Row="0" Grid.Column="1"
                                    Text="Delete"
                                    BackgroundColor="{AppThemeBinding Light=#E2E8F0, Dark=#334155}"
                                    TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ProjectsViewModel}}, Path=DeleteProjectCommand}"
                                    CommandParameter="{Binding .}" />

                            <!-- Description -->
                            <Label Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                   Text="{Binding Description}"
                                   FontSize="14"
                                   TextColor="{AppThemeBinding Light=#334155, Dark=#CBD5E1}"
                                   Margin="0,5,0,0" />

                            <!-- Metadata -->
                            <HorizontalStackLayout Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                                  Spacing="15"
                                                  Margin="0,10,0,0">
                                <Label Text="{Binding CreatedDate, StringFormat='Created: {0:MMM dd, yyyy}'}"
                                       FontSize="12"
                                       TextColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}" />
                                <Label Text="{Binding TaskCount, StringFormat='Tasks: {0}'}"
                                       FontSize="12"
                                       TextColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}" />
                            </HorizontalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Loading Indicator -->
        <ActivityIndicator Grid.Row="1"
                          IsRunning="{Binding IsBusy}"
                          IsVisible="{Binding IsBusy}"
                          Color="{StaticResource Primary}"
                          VerticalOptions="Center"
                          HorizontalOptions="Center" />
    </Grid>

</ContentPage>
