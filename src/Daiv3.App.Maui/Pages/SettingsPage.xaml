<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Daiv3.App.Maui.ViewModels"
             x:Class="Daiv3.App.Maui.Pages.SettingsPage"
             x:DataType="vm:SettingsViewModel"
             Title="{Binding Title}">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <!-- Header -->
            <Label Text="Application Settings"
                   FontSize="24"
                   FontAttributes="Bold"
                   HorizontalOptions="Center" />

            <!-- Directories Section -->
                <Border BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1A212B}"
                    Padding="15"
                    StrokeShape="RoundRectangle 10"
                    StrokeThickness="0">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Directories"
                           FontSize="18"
                           FontAttributes="Bold" />

                    <!-- Data Directory -->
                    <Label Text="Data Directory:" FontAttributes="Bold" FontSize="14" />
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="5">
                        <Entry Grid.Column="0"
                               Text="{Binding DataDirectory}"
                               IsReadOnly="True"
                               FontSize="12" />
                        <Button Grid.Column="1"
                                Text="Browse"
                                Command="{Binding BrowseDataDirectoryCommand}" />
                    </Grid>

                    <!-- Models Directory -->
                    <Label Text="Models Directory:" FontAttributes="Bold" FontSize="14" Margin="0,10,0,0" />
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="5">
                        <Entry Grid.Column="0"
                               Text="{Binding ModelsDirectory}"
                               IsReadOnly="True"
                               FontSize="12" />
                        <Button Grid.Column="1"
                                Text="Browse"
                                Command="{Binding BrowseModelsDirectoryCommand}" />
                    </Grid>

                    <!-- Foundry Models Directory -->
                    <Label Text="Foundry Models Directory:" FontAttributes="Bold" FontSize="14" Margin="0,10,0,0" />
                    <Entry Text="{Binding FoundryModelsDirectory}"
                           IsReadOnly="True"
                           FontSize="12" />
                </VerticalStackLayout>
            </Border>

            <!-- Hardware Preferences Section -->
                <Border BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1A212B}"
                    Padding="15"
                    StrokeShape="RoundRectangle 10"
                    StrokeThickness="0">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Hardware Preferences"
                           FontSize="18"
                           FontAttributes="Bold" />

                    <HorizontalStackLayout Spacing="10">
                        <CheckBox IsChecked="{Binding UseNpu}" />
                        <Label Text="Use NPU (Neural Processing Unit)"
                               VerticalOptions="Center"
                               FontSize="14" />
                    </HorizontalStackLayout>

                    <HorizontalStackLayout Spacing="10">
                        <CheckBox IsChecked="{Binding UseGpu}" />
                        <Label Text="Use GPU (Graphics Processing Unit)"
                               VerticalOptions="Center"
                               FontSize="14" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- Model Execution Section -->
                <Border BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1A212B}"
                    Padding="15"
                    StrokeShape="RoundRectangle 10"
                    StrokeThickness="0">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Model Execution"
                           FontSize="18"
                           FontAttributes="Bold" />

                    <HorizontalStackLayout Spacing="10">
                        <CheckBox IsChecked="{Binding AllowOnlineProviders}" />
                        <Label Text="Allow Online Providers (OpenAI, Azure, etc.)"
                               VerticalOptions="Center"
                               FontSize="14" />
                    </HorizontalStackLayout>

                    <Label Text="Token Budget:" FontAttributes="Bold" FontSize="14" Margin="0,10,0,0" />
                    <HorizontalStackLayout Spacing="10">
                        <Slider Value="{Binding TokenBudget}"
                                Minimum="2048"
                                Maximum="32768"
                                WidthRequest="250" />
                        <Label Text="{Binding TokenBudget}"
                               VerticalOptions="Center"
                               FontSize="14" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- Appearance Section -->
                <Border BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1A212B}"
                    Padding="15"
                    StrokeShape="RoundRectangle 10"
                    StrokeThickness="0">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Appearance"
                           FontSize="18"
                           FontAttributes="Bold" />

                    <Label Text="Theme:" FontAttributes="Bold" FontSize="14" />
                    <Picker SelectedItem="{Binding SelectedTheme}"
                            FontSize="14">
                        <Picker.ItemsSource>
                            <x:Array Type="{x:Type x:String}">
                                <x:String>Light</x:String>
                                <x:String>Dark</x:String>
                                <x:String>System</x:String>
                            </x:Array>
                        </Picker.ItemsSource>
                    </Picker>
                </VerticalStackLayout>
            </Border>

            <!-- Action Buttons -->
            <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                <Button Text="Save Settings"
                        Command="{Binding SaveSettingsCommand}"
                        WidthRequest="150" />
                <Button Text="Reset to Defaults"
                        Command="{Binding ResetSettingsCommand}"
                        BackgroundColor="{AppThemeBinding Light=#E2E8F0, Dark=#334155}"
                        TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}"
                        WidthRequest="150" />
            </HorizontalStackLayout>

            <!-- Loading Indicator -->
            <ActivityIndicator IsRunning="{Binding IsBusy}"
                              IsVisible="{Binding IsBusy}"
                              Color="{StaticResource Primary}"
                              VerticalOptions="Center"
                              HorizontalOptions="Center" />

            <!-- Info Note -->
            <Label Text="Settings are saved locally. Integration with configuration service pending."
                   FontSize="12"
                   TextColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center"
                   Margin="0,10,0,0" />
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
