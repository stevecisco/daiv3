<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Daiv3.App.Maui.ViewModels"
             x:Class="Daiv3.App.Maui.Pages.SettingsPage"
             x:DataType="vm:SettingsViewModel"
             Title="{Binding Title}">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">

            <Label Text="Application Settings"
                   FontSize="24"
                   FontAttributes="Bold"
                   HorizontalOptions="Center" />

            <Border BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1A212B}"
                    Padding="15"
                    StrokeShape="RoundRectangle 10"
                    StrokeThickness="0">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Directories"
                           FontSize="18"
                           FontAttributes="Bold" />

                    <Label Text="Data Directory:" FontAttributes="Bold" FontSize="14" />
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="5">
                        <Entry Grid.Column="0"
                               Text="{Binding DataDirectory}"
                               IsReadOnly="True"
                               FontSize="12" />
                        <Button Grid.Column="1"
                                Text="Browse"
                                Command="{Binding BrowseDataDirectoryCommand}" />
                    </Grid>

                    <Label Text="Models Directory:" FontAttributes="Bold" FontSize="14" Margin="0,10,0,0" />
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="5">
                        <Entry Grid.Column="0"
                               Text="{Binding ModelsDirectory}"
                               IsReadOnly="True"
                               FontSize="12" />
                        <Button Grid.Column="1"
                                Text="Browse"
                                Command="{Binding BrowseModelsDirectoryCommand}" />
                    </Grid>

                    <Label Text="Foundry Models Directory:" FontAttributes="Bold" FontSize="14" Margin="0,10,0,0" />
                    <Entry Text="{Binding FoundryModelsDirectory}"
                           IsReadOnly="True"
                           FontSize="12" />

                    <Label Text="Watched Directories (one per line):" FontAttributes="Bold" FontSize="14" Margin="0,10,0,0" />
                    <Editor Text="{Binding WatchedDirectories}"
                            AutoSize="TextChanges"
                            Placeholder="C:\\docs&#10;D:\\projects"
                            FontSize="12" />

                    <Label Text="Knowledge Back-Propagation Path:" FontAttributes="Bold" FontSize="14" Margin="0,10,0,0" />
                    <Entry Text="{Binding KnowledgeBackPropagationPath}"
                           FontSize="12" />
                </VerticalStackLayout>
            </Border>

            <Border BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1A212B}"
                    Padding="15"
                    StrokeShape="RoundRectangle 10"
                    StrokeThickness="0">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Model Preferences"
                           FontSize="18"
                           FontAttributes="Bold" />

                    <Label Text="Default Model:" FontAttributes="Bold" FontSize="14" />
                    <Entry Text="{Binding DefaultModel}" FontSize="12" />

                    <Label Text="Chat Model:" FontAttributes="Bold" FontSize="14" Margin="0,8,0,0" />
                    <Entry Text="{Binding ChatModel}" FontSize="12" />

                    <Label Text="Code Model:" FontAttributes="Bold" FontSize="14" Margin="0,8,0,0" />
                    <Entry Text="{Binding CodeModel}" FontSize="12" />

                    <Label Text="Reasoning Model:" FontAttributes="Bold" FontSize="14" Margin="0,8,0,0" />
                    <Entry Text="{Binding ReasoningModel}" FontSize="12" />
                </VerticalStackLayout>
            </Border>

            <Border BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1A212B}"
                    Padding="15"
                    StrokeShape="RoundRectangle 10"
                    StrokeThickness="0">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Hardware Preferences"
                           FontSize="18"
                           FontAttributes="Bold" />

                    <HorizontalStackLayout Spacing="10">
                        <CheckBox IsChecked="{Binding UseNpu}" />
                        <Label Text="Use NPU (Neural Processing Unit)"
                               VerticalOptions="Center"
                               FontSize="14" />
                    </HorizontalStackLayout>

                    <HorizontalStackLayout Spacing="10">
                        <CheckBox IsChecked="{Binding UseGpu}" />
                        <Label Text="Use GPU (Graphics Processing Unit)"
                               VerticalOptions="Center"
                               FontSize="14" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

            <Border BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1A212B}"
                    Padding="15"
                    StrokeShape="RoundRectangle 10"
                    StrokeThickness="0">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Online Access &amp; Budget Rules"
                           FontSize="18"
                           FontAttributes="Bold" />

                    <HorizontalStackLayout Spacing="10">
                        <CheckBox IsChecked="{Binding AllowOnlineProviders}" />
                        <Label Text="Allow Online Providers"
                               VerticalOptions="Center"
                               FontSize="14" />
                    </HorizontalStackLayout>

                    <Label Text="Online Access Mode:" FontAttributes="Bold" FontSize="14" />
                    <Picker SelectedItem="{Binding OnlineAccessMode}"
                            FontSize="14">
                        <Picker.ItemsSource>
                            <x:Array Type="{x:Type x:String}">
                                <x:String>never</x:String>
                                <x:String>ask</x:String>
                                <x:String>auto_within_budget</x:String>
                                <x:String>per_task</x:String>
                            </x:Array>
                        </Picker.ItemsSource>
                    </Picker>

                    <Label Text="Enabled Providers (comma-separated):" FontAttributes="Bold" FontSize="14" Margin="0,8,0,0" />
                    <Entry Text="{Binding OnlineProvidersEnabled}"
                           Placeholder="openai, azure_openai, anthropic"
                           FontSize="12" />

                    <Label Text="Daily Token Budget:" FontAttributes="Bold" FontSize="14" Margin="0,8,0,0" />
                    <Entry Text="{Binding TokenBudget}"
                           Keyboard="Numeric"
                           FontSize="12" />

                    <Label Text="Monthly Token Budget:" FontAttributes="Bold" FontSize="14" Margin="0,8,0,0" />
                    <Entry Text="{Binding MonthlyTokenBudget}"
                           Keyboard="Numeric"
                           FontSize="12" />

                    <Label Text="Alert Threshold (%):" FontAttributes="Bold" FontSize="14" Margin="0,8,0,0" />
                    <Entry Text="{Binding TokenBudgetAlertThreshold}"
                           Keyboard="Numeric"
                           FontSize="12" />

                    <Label Text="Budget Mode:" FontAttributes="Bold" FontSize="14" Margin="0,8,0,0" />
                    <Picker SelectedItem="{Binding TokenBudgetMode}"
                            FontSize="14">
                        <Picker.ItemsSource>
                            <x:Array Type="{x:Type x:String}">
                                <x:String>user_confirm</x:String>
                                <x:String>hard_stop</x:String>
                            </x:Array>
                        </Picker.ItemsSource>
                    </Picker>
                </VerticalStackLayout>
            </Border>

            <Border BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1A212B}"
                    Padding="15"
                    StrokeShape="RoundRectangle 10"
                    StrokeThickness="0">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Agents, Skills, Scheduling"
                           FontSize="18"
                           FontAttributes="Bold" />

                    <HorizontalStackLayout Spacing="10">
                        <CheckBox IsChecked="{Binding EnableAgents}" />
                        <Label Text="Enable Agents" VerticalOptions="Center" FontSize="14" />
                    </HorizontalStackLayout>

                    <HorizontalStackLayout Spacing="10">
                        <CheckBox IsChecked="{Binding EnableSkills}" />
                        <Label Text="Enable Skills" VerticalOptions="Center" FontSize="14" />
                    </HorizontalStackLayout>

                    <Label Text="Agent Iteration Limit:" FontAttributes="Bold" FontSize="14" Margin="0,8,0,0" />
                    <Entry Text="{Binding AgentIterationLimit}"
                           Keyboard="Numeric"
                           FontSize="12" />

                    <Label Text="Agent Token Budget:" FontAttributes="Bold" FontSize="14" Margin="0,8,0,0" />
                    <Entry Text="{Binding AgentTokenBudget}"
                           Keyboard="Numeric"
                           FontSize="12" />

                    <HorizontalStackLayout Spacing="10" Margin="0,8,0,0">
                        <CheckBox IsChecked="{Binding EnableScheduling}" />
                        <Label Text="Enable Scheduling" VerticalOptions="Center" FontSize="14" />
                    </HorizontalStackLayout>

                    <Label Text="Scheduler Check Interval (seconds):" FontAttributes="Bold" FontSize="14" />
                    <Entry Text="{Binding SchedulerCheckInterval}"
                           Keyboard="Numeric"
                           FontSize="12" />

                    <Label Text="Skill Marketplace URLs (one per line):" FontAttributes="Bold" FontSize="14" Margin="0,8,0,0" />
                    <Editor Text="{Binding SkillMarketplaceUrls}"
                            AutoSize="TextChanges"
                            Placeholder="https://example.com/skills.json"
                            FontSize="12" />
                </VerticalStackLayout>
            </Border>

            <Border BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1A212B}"
                    Padding="15"
                    StrokeShape="RoundRectangle 10"
                    StrokeThickness="0">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Appearance"
                           FontSize="18"
                           FontAttributes="Bold" />

                    <Label Text="Theme:" FontAttributes="Bold" FontSize="14" />
                    <Picker SelectedItem="{Binding SelectedTheme}"
                            FontSize="14">
                        <Picker.ItemsSource>
                            <x:Array Type="{x:Type x:String}">
                                <x:String>Light</x:String>
                                <x:String>Dark</x:String>
                                <x:String>System</x:String>
                            </x:Array>
                        </Picker.ItemsSource>
                    </Picker>
                </VerticalStackLayout>
            </Border>

            <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                <Button Text="Save Settings"
                        Command="{Binding SaveSettingsCommand}"
                        WidthRequest="150" />
                <Button Text="Reset to Defaults"
                        Command="{Binding ResetSettingsCommand}"
                        BackgroundColor="{AppThemeBinding Light=#E2E8F0, Dark=#334155}"
                        TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}"
                        WidthRequest="150" />
            </HorizontalStackLayout>

            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               Color="{StaticResource Primary}"
                               VerticalOptions="Center"
                               HorizontalOptions="Center" />

            <Label Text="Settings are stored locally and apply to directories, model preferences, budgets, online rules, agents, skills, scheduling, and marketplace sources."
                   FontSize="12"
                   TextColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center"
                   Margin="0,10,0,0" />
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
