<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Daiv3.App.Maui.ViewModels"
             xmlns:knowledge="clr-namespace:Daiv3.Knowledge;assembly=Daiv3.Knowledge"
             x:Class="Daiv3.App.Maui.Pages.IndexingPage"
             x:DataType="vm:IndexingViewModel"
             Title="{Binding Title}">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">

            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                <Label Grid.Column="0"
                       Text="Indexing Status"
                       FontSize="24"
                       FontAttributes="Bold"
                       VerticalOptions="Center" />

                <HorizontalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="6">
                    <Label Text="●"
                           FontSize="14"
                           TextColor="{Binding IsWatcherActive, Converter={StaticResource BoolToColorConverter}}"
                           VerticalOptions="Center" />
                    <Label Text="{Binding WatcherStatusText}"
                           FontSize="12"
                           VerticalOptions="Center" />
                </HorizontalStackLayout>
            </Grid>

            <Border BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1A212B}"
                    Padding="12"
                    StrokeShape="RoundRectangle 8"
                    StrokeThickness="0">
                <VerticalStackLayout Spacing="8">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                        <Label Text="Scan Status:" FontAttributes="Bold" />
                        <Label Grid.Column="1" Text="{Binding ScanStatus}" />
                    </Grid>

                    <ProgressBar Progress="{Binding IndexingProgress}" HeightRequest="8" />
                    <Label Text="{Binding IndexingProgress, StringFormat='Progress: {0:P0}'}"
                           FontSize="12"
                           TextColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}" />

                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                        <Label Text="Last Scan:" FontAttributes="Bold" />
                        <Label Grid.Column="1" Text="{Binding LastScanTime}" />
                    </Grid>

                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                        <Label Text="Duration:" FontAttributes="Bold" />
                        <Label Grid.Column="1" Text="{Binding LastScanDuration}" />
                    </Grid>

                    <Label Text="Errors/Warnings present"
                           TextColor="{StaticResource Danger}"
                           FontAttributes="Bold"
                           IsVisible="{Binding HasErrorIndicator}" />
                </VerticalStackLayout>
            </Border>

            <Border BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1A212B}"
                    Padding="15"
                    StrokeShape="RoundRectangle 10"
                    StrokeThickness="0">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Indexing Statistics"
                           FontSize="18"
                           FontAttributes="Bold" />

                    <Grid ColumnDefinitions="170,*" RowSpacing="4">
                        <Label Text="Discovered Files:" FontAttributes="Bold" />
                        <Label Grid.Column="1" Text="{Binding TotalDiscovered}" />

                        <Label Grid.Row="1" Text="Indexed:" FontAttributes="Bold" />
                        <Label Grid.Row="1" Grid.Column="1" Text="{Binding TotalIndexed}" />

                        <Label Grid.Row="2" Text="Not Indexed:" FontAttributes="Bold" />
                        <Label Grid.Row="2" Grid.Column="1" Text="{Binding TotalNotIndexed}" />

                        <Label Grid.Row="3" Text="In Progress:" FontAttributes="Bold" />
                        <Label Grid.Row="3" Grid.Column="1" Text="{Binding TotalInProgress}" />

                        <Label Grid.Row="4" Text="Errors:" FontAttributes="Bold" />
                        <Label Grid.Row="4" Grid.Column="1" Text="{Binding TotalErrors}" TextColor="{StaticResource Danger}" />

                        <Label Grid.Row="5" Text="Warnings:" FontAttributes="Bold" />
                        <Label Grid.Row="5" Grid.Column="1" Text="{Binding TotalWarnings}" TextColor="{StaticResource Warning}" />

                        <Label Grid.Row="6" Text="Storage Used:" FontAttributes="Bold" />
                        <Label Grid.Row="6" Grid.Column="1" Text="{Binding TotalStorageFormatted}" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Border BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1A212B}"
                    Padding="15"
                    StrokeShape="RoundRectangle 10"
                    StrokeThickness="0">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Filters"
                           FontSize="18"
                           FontAttributes="Bold" />

                    <Entry Placeholder="Search by file name or path"
                           Text="{Binding SearchText}"
                           ClearButtonVisibility="WhileEditing" />

                    <Picker Title="Filter by file type"
                            ItemsSource="{Binding AvailableFormats}"
                            SelectedItem="{Binding FormatFilter}" />

                    <FlexLayout Direction="Row" Wrap="Wrap" AlignItems="Start" JustifyContent="Start">
                        <Button Text="All" Command="{Binding ClearFiltersCommand}" FontSize="12" Padding="10,4" />
                        <Button Text="Indexed" Command="{Binding SetStatusFilterCommand}" CommandParameter="{x:Static knowledge:FileIndexingStatus.Indexed}" FontSize="12" Padding="10,4" />
                        <Button Text="Errors" Command="{Binding SetStatusFilterCommand}" CommandParameter="{x:Static knowledge:FileIndexingStatus.Error}" FontSize="12" Padding="10,4" />
                        <Button Text="In Progress" Command="{Binding SetStatusFilterCommand}" CommandParameter="{x:Static knowledge:FileIndexingStatus.InProgress}" FontSize="12" Padding="10,4" />
                        <Button Text="Pending" Command="{Binding SetStatusFilterCommand}" CommandParameter="{x:Static knowledge:FileIndexingStatus.NotIndexed}" FontSize="12" Padding="10,4" />
                        <Button Text="Warnings" Command="{Binding SetStatusFilterCommand}" CommandParameter="{x:Static knowledge:FileIndexingStatus.Warning}" FontSize="12" Padding="10,4" />
                        <Button Text="Refresh" Command="{Binding RefreshCommand}" FontSize="12" Padding="10,4" />
                    </FlexLayout>
                </VerticalStackLayout>
            </Border>

            <Border BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1A212B}"
                    Padding="15"
                    StrokeShape="RoundRectangle 10"
                    StrokeThickness="0">
                <VerticalStackLayout Spacing="10">
                    <Label Text="File Browser"
                           FontSize="18"
                           FontAttributes="Bold" />

                    <Label Text="{Binding FilteredFiles.Count, StringFormat='Filtered files: {0}'}"
                           FontSize="12"
                           TextColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}" />

                    <CollectionView ItemsSource="{Binding DirectoryGroups}"
                                    SelectionMode="None"
                                    HeightRequest="350">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="vm:DirectoryBrowserGroup">
                                <Border Padding="8"
                                        Margin="0,2"
                                        StrokeShape="RoundRectangle 6"
                                        StrokeThickness="1"
                                        Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#334155}">
                                    <VerticalStackLayout Spacing="6">
                                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                                            <Button Grid.Column="0"
                                                    Text="{Binding ExpansionGlyph}"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:IndexingViewModel}}, Path=ToggleDirectoryCommand}"
                                                    CommandParameter="{Binding DirectoryPath}"
                                                    FontSize="12"
                                                    Padding="2"
                                                    WidthRequest="28"
                                                    HeightRequest="28" />
                                            <Label Grid.Column="1"
                                                   Text="{Binding DisplayName}"
                                                   FontAttributes="Bold"
                                                   VerticalOptions="Center"
                                                   LineBreakMode="TailTruncation" />
                                            <Label Grid.Column="2"
                                                   Text="{Binding FileCount, StringFormat='{0}'}"
                                                   VerticalOptions="Center"
                                                   FontSize="12"
                                                   TextColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}" />
                                        </Grid>

                                        <CollectionView ItemsSource="{Binding Files}"
                                                        SelectionMode="None"
                                                        IsVisible="{Binding IsExpanded}">
                                            <CollectionView.ItemTemplate>
                                                <DataTemplate x:DataType="knowledge:FileIndexInfo">
                                                    <Border Padding="8"
                                                            Margin="20,1,0,1"
                                                            StrokeShape="RoundRectangle 6"
                                                            StrokeThickness="1"
                                                            Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#334155}"
                                                            BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#1E293B}">
                                                        <Border.GestureRecognizers>
                                                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:IndexingViewModel}}, Path=SelectFileCommand}"
                                                                                  CommandParameter="{Binding .}" />
                                                        </Border.GestureRecognizers>

                                                        <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="8">
                                                            <Label Grid.Column="0"
                                                                   Text="{Binding Status, Converter={StaticResource StatusIconConverter}}"
                                                                   FontSize="16"
                                                                   VerticalOptions="Center" />
                                                            <VerticalStackLayout Grid.Column="1" Spacing="2">
                                                                <Label Text="{Binding FileName}" LineBreakMode="TailTruncation" FontSize="12" />
                                                                <Label Text="{Binding Format, StringFormat='Type: {0}'}"
                                                                       FontSize="10"
                                                                       TextColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}" />
                                                            </VerticalStackLayout>
                                                            <Label Grid.Column="2"
                                                                   Text="🔒"
                                                                   IsVisible="{Binding IsSensitive}"
                                                                   VerticalOptions="Center" />
                                                            <Label Grid.Column="3"
                                                                   Text="{Binding SizeBytes, Converter={StaticResource BytesToStringConverter}}"
                                                                   FontSize="10"
                                                                   VerticalOptions="Center" />
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </CollectionView.ItemTemplate>
                                        </CollectionView>
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>

            <Border BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1A212B}"
                    Padding="15"
                    StrokeShape="RoundRectangle 10"
                    StrokeThickness="0"
                    IsVisible="{Binding SelectedFile, Converter={StaticResource IsNotNullConverter}}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="File Details"
                           FontSize="18"
                           FontAttributes="Bold" />

                    <Grid ColumnDefinitions="180,*" RowSpacing="4">
                        <Label Text="Name:" FontAttributes="Bold" />
                        <Label Grid.Column="1" Text="{Binding SelectedFile.FileName}" />

                        <Label Grid.Row="1" Text="Path:" FontAttributes="Bold" />
                        <Label Grid.Row="1" Grid.Column="1" Text="{Binding SelectedFile.FilePath}" LineBreakMode="CharacterWrap" />

                        <Label Grid.Row="2" Text="Directory:" FontAttributes="Bold" />
                        <Label Grid.Row="2" Grid.Column="1" Text="{Binding SelectedFile.DirectoryPath}" LineBreakMode="CharacterWrap" />

                        <Label Grid.Row="3" Text="Status:" FontAttributes="Bold" />
                        <Label Grid.Row="3" Grid.Column="1" Text="{Binding SelectedFile.Status}" />

                        <Label Grid.Row="4" Text="Type:" FontAttributes="Bold" />
                        <Label Grid.Row="4" Grid.Column="1" Text="{Binding SelectedFile.Format}" />

                        <Label Grid.Row="5" Text="Size:" FontAttributes="Bold" />
                        <Label Grid.Row="5" Grid.Column="1" Text="{Binding SelectedFile.SizeBytes, Converter={StaticResource BytesToStringConverter}}" />

                        <Label Grid.Row="6" Text="Indexed At:" FontAttributes="Bold" />
                        <Label Grid.Row="6" Grid.Column="1" Text="{Binding SelectedFileIndexedAtDisplay}" />

                        <Label Grid.Row="7" Text="Last Modified:" FontAttributes="Bold" />
                        <Label Grid.Row="7" Grid.Column="1" Text="{Binding SelectedFileLastModifiedDisplay}" />

                        <Label Grid.Row="8" Text="Embedding Status:" FontAttributes="Bold" />
                        <Label Grid.Row="8" Grid.Column="1" Text="{Binding SelectedFileEmbeddingStatus}" />

                        <Label Grid.Row="9" Text="Embedding Dim:" FontAttributes="Bold" />
                        <Label Grid.Row="9" Grid.Column="1" Text="{Binding SelectedFile.EmbeddingDimension, StringFormat='{0}D'}" />

                        <Label Grid.Row="10" Text="Chunks:" FontAttributes="Bold" />
                        <Label Grid.Row="10" Grid.Column="1" Text="{Binding SelectedFile.ChunkCount}" />

                        <Label Grid.Row="11" Text="Shareable:" FontAttributes="Bold" />
                        <Label Grid.Row="11" Grid.Column="1" Text="{Binding SelectedFile.IsShareable}" />

                        <Label Grid.Row="12" Text="Sensitive:" FontAttributes="Bold" />
                        <Label Grid.Row="12" Grid.Column="1" Text="{Binding SelectedFile.IsSensitive}" />

                        <Label Grid.Row="13" Text="Machine:" FontAttributes="Bold" />
                        <Label Grid.Row="13" Grid.Column="1" Text="{Binding SelectedFile.MachineLocation}" />
                    </Grid>

                    <VerticalStackLayout Spacing="4"
                                         IsVisible="{Binding SelectedFile.TopicSummary, Converter={StaticResource IsNotNullOrEmptyConverter}}">
                        <Label Text="Topic Summary:" FontAttributes="Bold" />
                        <Label Text="{Binding SelectedFile.TopicSummary}" FontSize="12" LineBreakMode="WordWrap" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="4"
                                         IsVisible="{Binding SelectedFile.ErrorMessage, Converter={StaticResource IsNotNullOrEmptyConverter}}">
                        <Label Text="Error:" FontAttributes="Bold" TextColor="{StaticResource Danger}" />
                        <Label Text="{Binding SelectedFile.ErrorMessage}" FontSize="12" TextColor="{StaticResource Danger}" LineBreakMode="WordWrap" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
