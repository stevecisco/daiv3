<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Daiv3.App.Maui.ViewModels"
             x:Class="Daiv3.App.Maui.Pages.AdminDashboardPage"
             x:DataType="vm:AdminDashboardViewModel"
             Title="{Binding Title}">

    <Grid RowDefinitions="Auto,*" Padding="0">
        
        <!-- Toolbar with Refresh and Polling Controls -->
        <Border Grid.Row="0"
                BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#0F172A}"
                Padding="20,12"
                StrokeThickness="0">
            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                <!-- Title and Last Updated -->
                <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                    <Label Text="System Admin Dashboard"
                           FontSize="22"
                           FontAttributes="Bold" />
                    <Label Text="{Binding LastUpdatedText}"
                           FontSize="12"
                           TextColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}" />
                </VerticalStackLayout>

                <!-- Refresh Button -->
                <Button Grid.Column="1"
                        Text="🔄 Refresh"
                        Command="{Binding RefreshMetricsCommand}"
                        Padding="12,6"
                        FontSize="13"
                        BackgroundColor="{StaticResource Primary}"
                        TextColor="White"
                        CornerRadius="6" />

                <!-- Polling Toggle -->
                  <Label Grid.Column="2"
                      Text="{Binding PollingStatusText}"
                       FontSize="13"
                       FontAttributes="Bold"
                       VerticalOptions="Center"
                       TextColor="{Binding IsPolling, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#16A34A|#EF4444'}" />
            </Grid>
        </Border>

        <!-- Main Content -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20" Spacing="15">

                <!-- Alerts Banner -->
                <Border BackgroundColor="{AppThemeBinding Light=#FEF2F2, Dark=#1C0A0A}"
                        Padding="15"
                        StrokeShape="RoundRectangle 10"
                        StrokeThickness="2"
                        Stroke="#EF4444"
                    IsVisible="{Binding HasAnyAlert}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="⚠ System Alerts"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="#EF4444" />

                        <Label Text="{Binding CpuAlertText}"
                               FontSize="12"
                               TextColor="{AppThemeBinding Light=#7F1D1D, Dark=#FCA5A5}"
                               IsVisible="{Binding HasHighCpuAlert}" />

                        <Label Text="{Binding MemoryAlertText}"
                               FontSize="12"
                               TextColor="{AppThemeBinding Light=#7F1D1D, Dark=#FCA5A5}"
                               IsVisible="{Binding HasHighMemoryAlert}" />

                        <Label Text="{Binding DiskAlertText}"
                               FontSize="12"
                               TextColor="{AppThemeBinding Light=#7F1D1D, Dark=#FCA5A5}"
                               IsVisible="{Binding HasLowDiskAlert}" />

                        <Label Text="{Binding QueueAlertText}"
                               FontSize="12"
                               TextColor="{AppThemeBinding Light=#7F1D1D, Dark=#FCA5A5}"
                               IsVisible="{Binding HasQueueBottleneckAlert}" />
                    </VerticalStackLayout>
                </Border>

                <!-- CPU Metrics -->
                <Border BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1A212B}"
                        Padding="15"
                        StrokeShape="RoundRectangle 10"
                        StrokeThickness="0">
                    <VerticalStackLayout Spacing="8">
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="CPU"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   VerticalOptions="Center" />
                            <Label Text="{Binding CpuPercentText}"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="{Binding CpuBarColor}"
                                   VerticalOptions="Center" />
                                <Label Text="{Binding CpuCoreCount, StringFormat='{0} cores'}"
                                   FontSize="11"
                                              TextColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}"
                                   VerticalOptions="Center" />
                        </HorizontalStackLayout>
                        <ProgressBar Progress="{Binding CpuProgress}"
                                     ProgressColor="{Binding CpuBarColor}"
                                     HeightRequest="10" />
                    </VerticalStackLayout>
                </Border>

                <!-- Memory Metrics -->
                <Border BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1A212B}"
                        Padding="15"
                        StrokeShape="RoundRectangle 10"
                        StrokeThickness="0">
                    <VerticalStackLayout Spacing="8">
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="Memory"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   VerticalOptions="Center" />
                            <Label Text="{Binding MemoryPercentText}"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="{Binding MemoryBarColor}"
                                   VerticalOptions="Center" />
                        </HorizontalStackLayout>
                        <ProgressBar Progress="{Binding MemoryProgress}"
                                     ProgressColor="{Binding MemoryBarColor}"
                                     HeightRequest="10" />
                        <Label Text="{Binding MemoryUsedText, StringFormat='Used: {0}'}"
                               FontSize="11"
                               TextColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}" />
                    </VerticalStackLayout>
                </Border>

                <!-- Disk Metrics -->
                <Border BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1A212B}"
                        Padding="15"
                        StrokeShape="RoundRectangle 10"
                        StrokeThickness="0">
                    <VerticalStackLayout Spacing="8">
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="Disk"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   VerticalOptions="Center" />
                            <Label Text="{Binding DiskPercentText}"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="{Binding DiskBarColor}"
                                   VerticalOptions="Center" />
                        </HorizontalStackLayout>
                        <ProgressBar Progress="{Binding DiskProgress}"
                                     ProgressColor="{Binding DiskBarColor}"
                                     HeightRequest="10" />
                        <Label Text="{Binding DiskUsedText, StringFormat='Free: {0}'}"
                               FontSize="11"
                               TextColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}" />
                    </VerticalStackLayout>
                </Border>

                <!-- GPU Metrics (if available) -->
                <Border BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1A212B}"
                        Padding="15"
                        StrokeShape="RoundRectangle 10"
                        StrokeThickness="0"
                    IsVisible="{Binding IsGpuAvailable}">
                    <VerticalStackLayout Spacing="8">
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="GPU"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   VerticalOptions="Center" />
                            <Label Text="{Binding GpuPercentText}"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="{Binding GpuBarColor}"
                                   VerticalOptions="Center" />
                        </HorizontalStackLayout>
                        <ProgressBar Progress="{Binding GpuProgress}"
                                     ProgressColor="{Binding GpuBarColor}"
                                     HeightRequest="10" />
                    </VerticalStackLayout>
                </Border>

                <!-- NPU Status (if available) -->
                  <Border BackgroundColor="{AppThemeBinding Light=#F0FDF4, Dark=#052E16}"
                        Padding="15"
                        StrokeShape="RoundRectangle 10"
                        StrokeThickness="0"
                       IsVisible="{Binding IsNpuAvailable}">
                    <HorizontalStackLayout Spacing="8">
                        <Label Text="NPU"
                               FontSize="14"
                               FontAttributes="Bold"
                               VerticalOptions="Center" />
                        <Label Text="Available"
                               FontSize="12"
                               TextColor="#16A34A"
                               VerticalOptions="Center" />
                       <Label Text="{Binding NpuExecutionProvider}"
                               FontSize="11"
                               TextColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </Border>

                <!-- Queue Status -->
                <Border BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1A212B}"
                        Padding="15"
                        StrokeShape="RoundRectangle 10"
                        StrokeThickness="0">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Queue Status"
                               FontSize="14"
                               FontAttributes="Bold" />
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                            <Label Grid.Column="0"
                                Text="{Binding TotalQueuedItems, StringFormat='Total: {0}'}"
                                   FontSize="12" />
                            <Label Grid.Column="1"
                                Text="{Binding CriticalPriorityCount, StringFormat='Critical: {0}'}"
                                   FontSize="12"
                                   TextColor="#EF4444" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Polling Control -->
                <Border BackgroundColor="{AppThemeBinding Light=#F0FDF4, Dark=#041A10}"
                        Padding="15"
                        StrokeShape="RoundRectangle 10"
                        StrokeThickness="0">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Polling Configuration"
                               FontSize="14"
                               FontAttributes="Bold" />
                        <Label Text="{Binding RefreshIntervalSeconds, StringFormat='Interval: {0} seconds'}"
                               FontSize="12"
                               TextColor="#16A34A" />
                        <Stepper Minimum="1" Maximum="30" Increment="1" Value="{Binding RefreshIntervalSeconds}" />
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                            <Button Grid.Column="0"
                                    Text="Start Polling"
                                    Command="{Binding StartPollingCommand}"
                                    BackgroundColor="#16A34A"
                                    TextColor="White" />
                            <Button Grid.Column="1"
                                    Text="Stop Polling"
                                    Command="{Binding StopPollingCommand}"
                                    BackgroundColor="#EF4444"
                                    TextColor="White" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>

</ContentPage>
